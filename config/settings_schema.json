[
  {
    "name": "theme_info",
    "theme_name": "Viha Heritage",
    "theme_version": "1.0.0",
    "theme_author": "Viha",
    "theme_documentation_url": "https://vihaheritage.com",
    "theme_support_url": "https://vihaheritage.com"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_maroon",
        "label": "Brand Green (Primary)",
        "default": "#0F5A43"
      },
      {
        "type": "color",
        "id": "color_maroon_dark",
        "label": "Brand Green Dark",
        "default": "#0B4533"
      },
      {
        "type": "color",
        "id": "color_gold",
        "label": "Brand Gold",
        "default": "#B8893D"
      },
      {
        "type": "color",
        "id": "color_cream",
        "label": "Brand Cream",
        "default": "#fdf9f1"
      },
      {
        "type": "color",
        "id": "color_cream_dark",
        "label": "Brand Cream Dark",
        "default": "#f1ede6"
      },
      {
        "type": "color",
        "id": "color_charcoal",
        "label": "Brand Charcoal",
        "default": "#2D2D2D"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font",
        "default": "libre_caslon_text_n7"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "inter_n4"
      }
    ]
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "range",
        "id": "logo_height",
        "min": 40,
        "max": 100,
        "step": 5,
        "unit": "px",
        "label": "Logo height (desktop)",
        "default": 70
      },
      {
        "type": "range",
        "id": "logo_height_mobile",
        "min": 30,
        "max": 70,
        "step": 5,
        "unit": "px",
        "label": "Logo height (mobile)",
        "default": 55
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image"
      }
    ]
  },
  {
    "name": "Social sharing",
    "settings": [
      {
        "type": "image_picker",
        "id": "social_share_image",
        "label": "Default social sharing image",
        "info": "Used when a page (e.g. homepage, custom pages) doesn't have its own image. Recommended: 1200 x 630px."
      }
    ]
  },
  {
    "name": "Business Info",
    "settings": [
      {
        "type": "text",
        "id": "business_street_address",
        "label": "Street address",
        "default": "No 10, Bhagirathy Street, Raja Annamalaipuram"
      },
      {
        "type": "text",
        "id": "business_city",
        "label": "City",
        "default": "Chennai"
      },
      {
        "type": "text",
        "id": "business_region",
        "label": "State/Region",
        "default": "Tamil Nadu"
      },
      {
        "type": "text",
        "id": "business_postal_code",
        "label": "Postal code",
        "default": "600028"
      },
      {
        "type": "text",
        "id": "business_country",
        "label": "Country",
        "default": "IN"
      },
      {
        "type": "text",
        "id": "business_phone",
        "label": "Showroom phone (with country code)",
        "default": "+91 88258 61822",
        "info": "Used for the LocalBusiness schema (Google Maps/local search) and can also be shown in the footer/contact page."
      },
      {
        "type": "text",
        "id": "business_hours_days",
        "label": "Open days",
        "default": "Mo-Sa",
        "info": "Schema.org day abbreviation range, e.g. Mo-Sa"
      },
      {
        "type": "text",
        "id": "business_hours_open",
        "label": "Opening time (24h)",
        "default": "10:00"
      },
      {
        "type": "text",
        "id": "business_hours_close",
        "label": "Closing time (24h)",
        "default": "18:00"
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "url",
        "id": "social_instagram_link",
        "label": "Instagram"
      },
      {
        "type": "url",
        "id": "social_facebook_link",
        "label": "Facebook"
      },
      {
        "type": "url",
        "id": "social_youtube_link",
        "label": "YouTube"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "drawer", "label": "Drawer" },
          { "value": "page", "label": "Page" }
        ],
        "default": "drawer"
      }
    ]
  }
]
