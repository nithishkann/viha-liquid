{%- comment -%}
  Article detail template — viha-theme
  Handles beauty journal articles at /blogs/beauty/[handle]
  Mirrors BeautyArticleView.tsx structure.
{%- endcomment -%}

{%- assign related_col = collections['ayurveda-herbal'] -%}
{%- assign other_articles = blog.articles -%}

<div style="background:var(--color-cream);">

  {%- comment -%} ── Hero image ─── {%- endcomment -%}
  <div style="position:relative;width:100%;height:clamp(300px,45vh,520px);overflow:hidden;">
    {%- if article.image -%}
      <img
        src="{{ article.image | img_url: '1920x' }}"
        alt="{{ article.image.alt | default: article.title | escape }}"
        loading="eager"
        fetchpriority="high"
        style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:brightness(0.48);">
    {%- else -%}
      <div style="position:absolute;inset:0;background:var(--color-maroon-dark);"></div>
    {%- endif -%}
    <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.85) 0%,rgba(0,0,0,0.20) 60%,transparent 100%);"></div>

    {%- comment -%} Breadcrumb {%- endcomment -%}
    <nav aria-label="Breadcrumb" style="position:absolute;top:1.5rem;left:3rem;display:flex;align-items:center;gap:6px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.18em;color:rgba(255,255,255,0.45);">
      <a href="/" style="color:inherit;transition:color 0.15s;" onmouseover="this.style.color='var(--color-gold)'" onmouseout="this.style.color='rgba(255,255,255,0.45)'">Home</a>
      <span>/</span>
      <a href="{{ blog.url }}" style="color:inherit;transition:color 0.15s;" onmouseover="this.style.color='var(--color-gold)'" onmouseout="this.style.color='rgba(255,255,255,0.45)'">{{ blog.title }}</a>
      <span>/</span>
      <span style="color:var(--color-gold);max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ article.title | truncate: 30 }}</span>
    </nav>

    <div style="position:absolute;bottom:0;left:0;right:0;padding:0 3rem 3rem;">
      {%- for tag in article.tags limit: 1 -%}
        <span style="display:inline-block;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:var(--color-gold);border:1px solid rgba(184,137,61,0.45);padding:3px 9px;border-radius:2px;margin-bottom:1rem;">{{ tag }}</span>
      {%- endfor -%}
      <h1 style="font-family:var(--font-heading);font-size:clamp(1.5rem,4vw,3rem);font-weight:900;color:#fff;max-width:700px;line-height:1.1;margin-bottom:1rem;">
        {{ article.title }}
      </h1>
      <div style="display:flex;align-items:center;gap:1.25rem;font-size:11px;color:rgba(255,255,255,0.50);flex-wrap:wrap;">
        <span style="display:flex;align-items:center;gap:5px;">
          <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          {{ article.published_at | time_tag: '%B %e, %Y' }}
        </span>
        <span style="color:rgba(255,255,255,0.20);">|</span>
        <span>{{ blog.title }}</span>
        {%- if article.author != blank -%}
          <span style="color:rgba(255,255,255,0.20);">|</span>
          <span>By {{ article.author }}</span>
        {%- endif -%}
      </div>
    </div>
  </div>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ shop.url | json }} },
      { "@type": "ListItem", "position": 2, "name": {{ blog.title | json }}, "item": {{ shop.url | append: blog.url | json }} },
      { "@type": "ListItem", "position": 3, "name": {{ article.title | json }}, "item": {{ shop.url | append: article.url | json }} }
    ]
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": {{ article.title | json }},
    "url": {{ shop.url | append: article.url | json }},
    "datePublished": {{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' | json }}
    {%- if article.updated_at -%},"dateModified": {{ article.updated_at | date: '%Y-%m-%dT%H:%M:%S%z' | json }}{%- endif -%}
    {%- if article.image -%},"image": {{ article.image | img_url: '1200x' | prepend: 'https:' | json }}{%- endif -%}
    {%- if article.author != blank -%},"author": { "@type": "Person", "name": {{ article.author | json }} }{%- endif -%},
    "publisher": {
      "@type": "Organization",
      "name": {{ shop.name | json }}
      {%- if settings.favicon != blank -%},"logo": { "@type": "ImageObject", "url": {{ settings.favicon | img_url: '512x512' | prepend: 'https:' | json }} }{%- endif -%}
    },
    "description": {{ article.excerpt_or_content | strip_html | truncate: 200 | json }}
  }
  </script>

  {%- comment -%} ── Back link ─── {%- endcomment -%}
  <div style="padding:1.25rem 3rem;border-bottom:1px solid var(--color-cream-dark);background:var(--color-paper);">
    <a href="{{ blog.url }}" style="display:inline-flex;align-items:center;gap:8px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.14em;color:rgba(45,45,45,0.55);transition:color 0.15s;" onmouseover="this.style.color='var(--color-maroon)'" onmouseout="this.style.color='rgba(45,45,45,0.55)'">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
      Back to {{ blog.title }}
    </a>
  </div>

  {%- comment -%} ── Article body ─── {%- endcomment -%}
  <div style="max-width:760px;margin:0 auto;padding:4rem 3rem 5rem;">

    {%- if article.excerpt -%}
      <p style="font-size:1.05rem;color:rgba(45,45,45,0.72);line-height:1.85;font-style:italic;font-family:var(--font-heading);border-left:4px solid var(--color-gold);padding-left:1.25rem;margin-bottom:3.5rem;">
        {{ article.excerpt | strip_html }}
      </p>
    {%- endif -%}

    <div class="article-content" style="font-size:15px;color:rgba(45,45,45,0.82);line-height:1.85;">
      {{ article.content }}
    </div>

    {%- comment -%} Article tags {%- endcomment -%}
    {%- if article.tags.size > 0 -%}
      <div style="margin-top:3rem;padding-top:1.5rem;border-top:1px solid var(--color-cream-dark);display:flex;align-items:center;flex-wrap:wrap;gap:8px;">
        <span style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.14em;color:rgba(45,45,45,0.40);margin-right:4px;">Topics:</span>
        {%- for tag in article.tags -%}
          <a href="{{ blog.url }}/tagged/{{ tag | handle }}" style="display:inline-block;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-maroon);background:rgba(15,90,67,0.07);border:1px solid rgba(15,90,67,0.15);padding:4px 10px;border-radius:2px;transition:all 0.15s;" onmouseover="this.style.background='var(--color-maroon)';this.style.color='#fff'" onmouseout="this.style.background='rgba(15,90,67,0.07)';this.style.color='var(--color-maroon)'">
            {{ tag }}
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} Author / footer {%- endcomment -%}
    <div style="margin-top:3rem;padding-top:1.5rem;border-top:1px solid var(--color-cream-dark);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
      <div>
        <p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.14em;color:var(--color-gold);">Written by</p>
        <p style="font-family:var(--font-heading);font-size:0.95rem;font-weight:700;color:var(--color-maroon);margin-top:2px;">
          {%- if article.author != blank -%}{{ article.author }}{%- else -%}Viha Beauty Journal{%- endif -%}
        </p>
        <p style="font-size:11px;color:rgba(45,45,45,0.45);margin-top:2px;">{{ article.published_at | time_tag: '%B %Y' }}</p>
      </div>
      <a href="{{ blog.url }}" style="display:inline-flex;align-items:center;gap:8px;padding:10px 20px;border:1px solid rgba(15,90,67,0.30);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:var(--color-maroon);border-radius:2px;transition:all 0.2s;" onmouseover="this.style.background='var(--color-maroon)';this.style.color='#fff'" onmouseout="this.style.background='';this.style.color='var(--color-maroon)'">
        <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
        More Articles
      </a>
    </div>

    {%- comment -%} Social share {%- endcomment -%}
    <div style="margin-top:2rem;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
      <span style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.14em;color:rgba(45,45,45,0.40);">Share:</span>
      <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ article.url }}" target="_blank" rel="noopener" aria-label="Share on Facebook" style="display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:600;color:var(--color-maroon);padding:5px 12px;border:1px solid var(--color-cream-dark);border-radius:2px;transition:all 0.15s;" onmouseover="this.style.background='var(--color-maroon)';this.style.color='#fff';this.style.borderColor='var(--color-maroon)'" onmouseout="this.style.background='';this.style.color='var(--color-maroon)';this.style.borderColor='var(--color-cream-dark)'">Facebook</a>
      <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ article.url }}&text={{ article.title | url_encode }}" target="_blank" rel="noopener" aria-label="Share on Twitter" style="display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:600;color:var(--color-maroon);padding:5px 12px;border:1px solid var(--color-cream-dark);border-radius:2px;transition:all 0.15s;" onmouseover="this.style.background='var(--color-maroon)';this.style.color='#fff';this.style.borderColor='var(--color-maroon)'" onmouseout="this.style.background='';this.style.color='var(--color-maroon)';this.style.borderColor='var(--color-cream-dark)'">Twitter</a>
      <a href="https://wa.me/?text={{ article.title | url_encode }}%20{{ shop.url }}{{ article.url }}" target="_blank" rel="noopener" aria-label="Share on WhatsApp" style="display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:600;color:var(--color-maroon);padding:5px 12px;border:1px solid var(--color-cream-dark);border-radius:2px;transition:all 0.15s;" onmouseover="this.style.background='var(--color-maroon)';this.style.color='#fff';this.style.borderColor='var(--color-maroon)'" onmouseout="this.style.background='';this.style.color='var(--color-maroon)';this.style.borderColor='var(--color-cream-dark)'">WhatsApp</a>
    </div>
  </div>

  {%- comment -%} ── Related products from collection ─── {%- endcomment -%}
  {%- if related_col != blank and related_col.products_count > 0 -%}
    <section style="padding:4rem 3rem;background:var(--color-paper);border-top:1px solid var(--color-cream-dark);">
      <div style="max-width:var(--max-w);margin:0 auto;">
        <div style="margin-bottom:2rem;">
          <span style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;color:var(--color-gold);margin-bottom:0.5rem;">From the Article</span>
          <h2 style="font-family:var(--font-heading);font-size:clamp(1.25rem,3vw,1.875rem);font-weight:900;color:var(--color-maroon);">Products Mentioned</h2>
        </div>
        <div class="collection-grid">
          {%- for product in related_col.products limit: 4 -%}
            {%- render 'product-card', product: product -%}
          {%- endfor -%}
        </div>
        <div style="text-align:center;margin-top:2rem;">
          <a href="/collections/ayurveda-herbal" class="btn btn--outline-maroon" style="display:inline-flex;align-items:center;gap:8px;padding:12px 24px;font-size:11px;">
            View All Beauty Products
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </a>
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ── More from the journal ─── {%- endcomment -%}
  {%- assign other_count = 0 -%}
  {%- for a in other_articles -%}
    {%- if a.handle != article.handle -%}
      {%- assign other_count = other_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if other_count > 0 -%}
    <section style="padding:4rem 3rem;background:var(--color-cream);border-top:1px solid var(--color-cream-dark);">
      <div style="max-width:var(--max-w);margin:0 auto;">
        <div style="margin-bottom:2rem;">
          <span style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;color:var(--color-gold);margin-bottom:0.5rem;">Continue Reading</span>
          <h2 style="font-family:var(--font-heading);font-size:clamp(1.25rem,3vw,1.875rem);font-weight:900;color:var(--color-maroon);">More from the Journal</h2>
        </div>

        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1.5rem;">
          {%- assign shown = 0 -%}
          {%- for a in other_articles -%}
            {%- if a.handle != article.handle and shown < 2 -%}
              {%- assign shown = shown | plus: 1 -%}
              <article style="border:1px solid var(--color-cream-dark);border-top:2px solid transparent;border-radius:2px;overflow:hidden;background:var(--color-paper);display:flex;transition:box-shadow 0.2s,border-top-color 0.2s;"
                onmouseover="this.style.boxShadow='0 4px 18px rgba(0,0,0,0.09)';this.style.borderTopColor='var(--color-gold)'"
                onmouseout="this.style.boxShadow='';this.style.borderTopColor='transparent'">
                {%- if a.image -%}
                  <a href="{{ a.url }}" style="display:block;width:160px;flex-shrink:0;overflow:hidden;" aria-hidden="true">
                    <img src="{{ a.image | img_url: '300x' }}" alt="{{ a.image.alt | default: a.title | escape }}" loading="lazy" style="width:100%;height:100%;object-fit:cover;transition:transform 0.5s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform=''">
                  </a>
                {%- endif -%}
                <div style="padding:1.25rem;display:flex;flex-direction:column;gap:0.5rem;justify-content:space-between;flex:1;">
                  <div>
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.5rem;">
                      {%- for tag in a.tags limit: 1 -%}
                        <span style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:var(--color-gold);">{{ tag }}</span>
                      {%- endfor -%}
                      <span style="font-size:9px;color:rgba(45,45,45,0.40);">{{ a.published_at | time_tag: '%b %Y' }}</span>
                    </div>
                    <h3 style="font-family:var(--font-heading);font-size:0.95rem;font-weight:700;color:var(--color-maroon);line-height:1.3;margin-bottom:0.5rem;">
                      <a href="{{ a.url }}" style="color:inherit;">{{ a.title }}</a>
                    </h3>
                    {%- if a.excerpt -%}
                      <p style="font-size:11px;color:rgba(45,45,45,0.60);line-height:1.6;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{{ a.excerpt | strip_html }}</p>
                    {%- endif -%}
                  </div>
                  <a href="{{ a.url }}" style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:var(--color-maroon);display:inline-flex;align-items:center;gap:4px;transition:gap 0.15s;margin-top:0.5rem;" onmouseover="this.style.gap='8px'" onmouseout="this.style.gap='4px'">
                    Read <svg width="10" height="10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
                  </a>
                </div>
              </article>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <div style="text-align:center;margin-top:2rem;">
          <a href="{{ blog.url }}" class="btn btn--ghost" style="display:inline-flex;align-items:center;gap:8px;padding:12px 24px;font-size:11px;">
            View All Articles
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </a>
        </div>
      </div>
    </section>
  {%- endif -%}

</div>

{%- comment -%} Article body prose styles {%- endcomment -%}
<style>
.article-content h2,
.article-content h3,
.article-content h4 {
  font-family: var(--font-heading);
  font-weight: 700;
  color: var(--color-maroon);
  margin: 2.5rem 0 1rem;
  line-height: 1.25;
}
.article-content h2 { font-size: clamp(1.25rem, 2.5vw, 1.625rem); }
.article-content h3 { font-size: 1.125rem; }
.article-content p  { margin: 0 0 1.25rem; }
.article-content p:last-child { margin-bottom: 0; }
.article-content blockquote {
  border-left: 4px solid var(--color-gold);
  background: var(--color-paper);
  padding: 1.25rem 1.5rem;
  margin: 2rem 0;
  font-family: var(--font-heading);
  font-style: italic;
  font-size: 1.05rem;
  color: var(--color-maroon);
  line-height: 1.65;
}
.article-content img {
  width: 100%;
  height: auto;
  border-radius: 2px;
  margin: 2rem 0;
  object-fit: cover;
}
.article-content a { color: var(--color-maroon); text-decoration: underline; }
.article-content a:hover { color: var(--color-gold); }
.article-content ul,
.article-content ol {
  padding-left: 1.5rem;
  margin: 1rem 0 1.25rem;
}
.article-content li { margin-bottom: 0.5rem; }
.article-content hr {
  border: none;
  border-top: 1px solid var(--color-cream-dark);
  margin: 2.5rem 0;
}
</style>
