{%- comment -%}
  Newsletter signup strip — viha-theme
  Reusable on blog listing (and elsewhere via Theme Editor "Add section").
{%- endcomment -%}

<section style="padding:4rem 3rem;background:var(--color-maroon-dark);text-align:center;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;opacity:0.05;background-image:radial-gradient(circle,#B8893D 1px,transparent 1px);background-size:16px 16px;pointer-events:none;"></div>
  <div style="max-width:420px;margin:0 auto;position:relative;z-index:1;">
    <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" style="color:var(--color-gold);margin:0 auto 1rem;display:block;" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
    </svg>
    <h2 style="font-family:var(--font-heading);font-size:1.5rem;font-weight:900;color:#fff;margin-bottom:0.75rem;">{{ section.settings.heading }}</h2>
    <p style="font-size:13px;color:rgba(255,255,255,0.55);margin-bottom:1.75rem;line-height:1.75;">{{ section.settings.subtext }}</p>
    {% form 'customer', id: 'newsletter-signup-form' %}
      {% if form.posted_successfully? %}
        <p role="status" style="font-size:13px;color:var(--color-gold);border:1px solid rgba(184,137,61,0.4);border-radius:2px;padding:13px 16px;line-height:1.6;">Welcome to the Viha family — you're subscribed. Nandri!</p>
      {% else %}
        {% if form.errors %}
          <p role="alert" style="font-size:12px;color:#f3c0b5;margin-bottom:10px;line-height:1.6;">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>
        {% endif %}
        <div style="display:flex;gap:8px;">
          <input type="hidden" name="contact[tags]" value="newsletter">
          <label for="newsletter-email" class="sr-only">Email address</label>
          <input type="email" name="contact[email]" id="newsletter-email" required autocomplete="email" placeholder="your@email.com" aria-label="Email address"
            style="flex:1;min-width:0;padding:13px 16px;border:1px solid rgba(255,255,255,0.20);background:rgba(255,255,255,0.07);color:#fff;font-size:16px;border-radius:2px;font-family:inherit;outline:none;" onfocus="this.style.borderColor='var(--color-gold)'" onblur="this.style.borderColor='rgba(255,255,255,0.20)'">
          <button type="submit" class="btn btn--gold" style="padding:13px 18px;white-space:nowrap;font-size:11px;">Subscribe</button>
        </div>
        <p style="font-size:10px;color:rgba(255,255,255,0.30);margin-top:10px;">No spam. Unsubscribe anytime.</p>
      {% endif %}
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter Signup",
  "settings": [
    { "type": "text",     "id": "heading", "label": "Heading", "default": "The Beauty Digest" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Seasonal rituals, Ayurvedic wisdom, and early access to new formulations — delivered twice a month." }
  ],
  "presets": [{ "name": "Newsletter Signup" }]
}
{% endschema %}
