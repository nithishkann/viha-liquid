{%- assign journal_blog = section.settings.blog | default: blogs['news'] -%}
{%- if journal_blog and journal_blog.articles_count > 0 -%}
<section class="section journal-section" aria-labelledby="journal-heading">
  <div class="container">
    <div class="section__header-row">
      <div>
        <p class="section__eyebrow">{{ section.settings.eyebrow | default: 'FROM OUR JOURNAL' }}</p>
        <h2 class="section__heading font-serif" id="journal-heading">{{ section.settings.heading | default: 'Stories, Rituals & Wisdom' }}</h2>
      </div>
      <a href="{{ journal_blog.url }}" class="section__view-all">
        View All
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
      </a>
    </div>
    <div class="journal__grid">
      {%- for article in journal_blog.articles limit: section.settings.posts_to_show -%}
        {%- assign journal_excerpt = article.excerpt | strip_html | strip_newlines -%}
        {%- if journal_excerpt == blank -%}
          {%- assign journal_excerpt = article.content | strip_html | strip_newlines | truncate: 110 -%}
        {%- endif -%}
        <a href="{{ article.url }}" class="journal__card">
          {%- if article.image -%}
            <img src="{{ article.image | image_url: width: 600, height: 400, crop: 'center' }}" alt="{{ article.image.alt | default: article.title | escape }}" class="journal__img" width="600" height="400" loading="lazy">
          {%- endif -%}
          <div class="journal__card-body">
            <p class="journal__date">{{ article.published_at | date: '%b %d, %Y' }}</p>
            <p class="journal__title">{{ article.title }}</p>
            <p class="journal__excerpt">{{ journal_excerpt }}</p>
            <span class="journal__link">
              Read Article
              <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
            </span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Latest Journal",
  "settings": [
    { "type": "text",  "id": "eyebrow",        "label": "Eyebrow text",    "default": "FROM OUR JOURNAL" },
    { "type": "text",  "id": "heading",        "label": "Section heading", "default": "Stories, Rituals & Wisdom" },
    { "type": "blog",  "id": "blog",           "label": "Blog to display", "info": "Defaults to the \"News\" blog if left blank" },
    { "type": "range", "id": "posts_to_show",  "label": "Posts to show", "min": 2, "max": 6, "step": 1, "default": 3 }
  ],
  "presets": [{ "name": "Latest Journal" }]
}
{% endschema %}
