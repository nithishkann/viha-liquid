<section class="section tracker-section" aria-labelledby="tracker-heading">
  <div class="tracker__inner container">

    <div class="tracker__content">
      <p class="section__eyebrow" style="color:rgba(255,255,255,0.55);">{{ section.settings.eyebrow | default: 'ORDER STATUS' }}</p>
      <h2 class="font-serif tracker__heading" id="tracker-heading">{{ section.settings.heading | default: 'Track Your Spiritual Journey' }}</h2>
      <div class="ornament-line-gold" aria-hidden="true" style="margin:1rem 0;">
        <span class="ornament-diamond-gold">◆</span>
      </div>
      <p class="tracker__sub">{{ section.settings.subtext | default: 'Enter your Viha order ID to get real-time updates on your sacred items.' }}</p>

      <form class="tracker__form" action="/pages/track-order" method="get" role="search">
        <label for="tracker-input" class="sr-only">Order ID</label>
        <div class="tracker__form-row">
          <input
            id="tracker-input"
            type="text"
            name="order"
            placeholder="e.g. #1234"
            class="tracker__input"
            autocomplete="off"
            required
            aria-label="Enter your Viha order ID"
          >
          <button type="submit" class="tracker__btn">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 15.803 7.5 7.5 0 0015.803 15.803z"/>
            </svg>
            Track Order
          </button>
        </div>
      </form>

      <div class="tracker__result" data-tracker-result hidden aria-live="polite"></div>

      <p class="tracker__hint">
        <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="display:inline;vertical-align:middle;" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/></svg>
        Orders are dispatched within 2-3 business days. For international orders, customs clearance may add 5-10 extra days.
      </p>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Order Tracker",
  "settings": [
    { "type": "text",     "id": "eyebrow", "label": "Eyebrow text", "default": "ORDER STATUS" },
    { "type": "text",     "id": "heading", "label": "Heading",      "default": "Track Your Spiritual Journey" },
    { "type": "textarea", "id": "subtext", "label": "Subtext",      "default": "Enter your Viha order ID to get real-time updates on your sacred items." }
  ],
  "presets": [{ "name": "Order Tracker" }]
}
{% endschema %}
